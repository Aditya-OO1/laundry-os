{
  "info": {
    "name": "LaundryOS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Store Admin\",\n  \"email\": \"admin@laundry.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const r = pm.response.json(); if(r.token) pm.collectionVariables.set('token', r.token);"]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@laundry.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Rahul Sharma\",\n    \"phone\": \"9812345678\"\n  },\n  \"garments\": [\n    { \"name\": \"Shirt\", \"qty\": 3 },\n    { \"name\": \"Pants\", \"qty\": 2 },\n    { \"name\": \"Saree\", \"qty\": 1 }\n  ],\n  \"estimatedDeliveryDays\": 2\n}"
            }
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base}}/orders",
              "query": [
                { "key": "status", "value": "RECEIVED", "disabled": true },
                { "key": "search", "value": "Rahul", "disabled": true },
                { "key": "garment", "value": "Shirt", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/orders/ORD-0001"
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/orders/ORD-0001/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PROCESSING\"\n}"
            }
          }
        },
        {
          "name": "Get Garment Prices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/orders/meta/garments"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/dashboard"
          }
        }
      ]
    }
  ]
}
